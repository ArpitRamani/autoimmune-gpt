# Copy this file to ".env" and paste your key in.
#
# Embeddings (retrieval) run locally with no API key, so you only need ONE key:
# the provider that writes the answers.

# Answer provider: "anthropic" (default) or "gemini".
CHAT_PROVIDER=anthropic

# Anthropic key — required for the default (Claude) setup.
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5

# Local embedding model (no key, runs on-device). Usually no need to change.
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Optional: only if you set CHAT_PROVIDER=gemini ---
# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.0-flash

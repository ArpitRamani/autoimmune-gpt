# Copy this file to ".env" and paste your real key(s) in.

# Gemini key — always required (used for the embeddings / retrieval step).
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Who writes the answers: "gemini" (default) or "anthropic".
CHAT_PROVIDER=gemini

# Anthropic key — only needed when CHAT_PROVIDER=anthropic.
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Models (defaults are the cheapest sensible choices — usually no need to change)
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5
